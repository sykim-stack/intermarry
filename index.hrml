<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>인터메리 — 국제결혼 이후의 삶</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@300;400;600&family=Noto+Sans+KR:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">

<style>
  :root {
    --bg:      #080808;
    --bg2:     #0f0f0f;
    --bg3:     #161616;
    --border:  rgba(255,255,255,0.07);
    --text:    #e8e0d4;
    --muted:   #666;
    --accent:  #c9a96e;
    --accent2: #8b6f47;
    --serif:   'Noto Serif KR', serif;
    --sans:    'Noto Sans KR', sans-serif;
    --mono:    'DM Mono', monospace;
  }

  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    overflow-x: hidden;
  }

  /* HEADER */
  header {
    position: fixed; top:0; left:0; right:0; z-index:100;
    padding: 20px 32px;
    display: flex; align-items:center; justify-content:space-between;
    background: linear-gradient(to bottom, rgba(8,8,8,0.95), transparent);
    backdrop-filter: blur(12px);
  }

  .logo {
    font-family: var(--serif); font-size:17px;
    font-weight:600; letter-spacing:4px;
    color: var(--accent); text-decoration:none;
  }
  .logo span { color: var(--text); font-weight:300; }

  .header-right {
    font-family: var(--mono); font-size:10px;
    letter-spacing:2px; color: var(--muted);
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction:column;
    align-items:center; justify-content:center;
    padding: 140px 24px 100px;
    text-align: center;
    position: relative;
  }

  .hero-label {
    font-family: var(--mono); font-size:10px;
    letter-spacing:4px; color: var(--accent);
    margin-bottom: 32px;
    opacity:0; animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(34px, 6vw, 64px);
    font-weight: 300; line-height: 1.35;
    letter-spacing: -0.5px;
    margin-bottom: 28px;
    opacity:0; animation: fadeUp 0.8s ease 0.4s forwards;
  }

  .hero-title em { font-style:normal; color: var(--accent); }

  .hero-sub {
    font-size: 15px; color: var(--muted);
    line-height: 1.9; max-width: 500px;
    margin-bottom: 16px;
    opacity:0; animation: fadeUp 0.8s ease 0.6s forwards;
  }

  .hero-note {
    font-family: var(--mono); font-size:11px;
    color: var(--muted); letter-spacing:1px;
    margin-bottom: 52px;
    opacity:0; animation: fadeUp 0.8s ease 0.7s forwards;
  }

  .hero-cta {
    display:flex; gap:12px; flex-wrap:wrap; justify-content:center;
    opacity:0; animation: fadeUp 0.8s ease 0.8s forwards;
  }

  .btn-primary {
    background: var(--accent); color:#080808;
    border:none; cursor:pointer;
    font-family: var(--sans); font-size:13px;
    font-weight:500; letter-spacing:1px;
    padding: 16px 36px; border-radius:2px;
    transition: all 0.3s;
  }
  .btn-primary:hover {
    background:#d4b47a; transform:translateY(-2px);
    box-shadow: 0 8px 32px rgba(201,169,110,0.25);
  }

  .btn-ghost {
    background:transparent; color: var(--muted);
    border: 1px solid var(--border); cursor:pointer;
    font-family: var(--sans); font-size:13px;
    letter-spacing:1px; padding:16px 36px;
    border-radius:2px; transition:all 0.3s;
  }
  .btn-ghost:hover { color: var(--text); border-color:rgba(255,255,255,0.2); }

  .scroll-hint {
    position:absolute; bottom:40px;
    display:flex; flex-direction:column; align-items:center; gap:8px;
    opacity:0; animation: fadeUp 1s ease 1.2s forwards;
  }
  .scroll-hint span { font-family:var(--mono); font-size:9px; letter-spacing:3px; color:var(--muted); }
  .scroll-line { width:1px; height:40px; background:linear-gradient(to bottom, var(--accent), transparent); animation:scrollPulse 2s ease infinite; }

  /* STORY SECTION */
  .story-section {
    padding: 120px 24px;
    max-width: 800px; margin:0 auto;
    text-align:center;
  }

  .section-eyebrow {
    font-family: var(--mono); font-size:10px;
    letter-spacing:4px; color: var(--accent);
    margin-bottom:20px;
  }

  .section-title {
    font-family: var(--serif);
    font-size: clamp(26px, 4vw, 40px);
    font-weight:300; line-height:1.4;
    margin-bottom:24px;
  }

  .section-body {
    font-size:15px; color: var(--muted);
    line-height:1.9; max-width:560px; margin:0 auto;
  }

  /* CONCERN GRID */
  .concern-section {
    padding: 80px 24px;
    max-width:1000px; margin:0 auto;
  }

  .concern-grid {
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap:1px; background: var(--border);
    border:1px solid var(--border);
    margin-top:56px;
  }

  .concern-item {
    background: var(--bg);
    padding: 36px 28px;
    transition: background 0.3s;
  }
  .concern-item:hover { background: var(--bg2); }

  .concern-icon { font-size:24px; margin-bottom:16px; }

  .concern-title {
    font-family: var(--serif); font-size:16px;
    font-weight:400; margin-bottom:10px;
  }

  .concern-desc {
    font-size:13px; color: var(--muted); line-height:1.7;
  }

  /* JOURNEY SECTION */
  .journey-section {
    background: var(--bg2);
    border-top:1px solid var(--border);
    border-bottom:1px solid var(--border);
    padding: 120px 24px;
  }

  .journey-inner {
    max-width:800px; margin:0 auto; text-align:center;
  }

  .journey-title {
    font-family: var(--serif);
    font-size: clamp(26px, 4vw, 40px);
    font-weight:300; line-height:1.4;
    margin-bottom:16px;
  }

  .journey-sub {
    font-size:14px; color: var(--muted);
    line-height:1.8; margin-bottom:64px;
  }

  .timeline {
    display:flex; flex-direction:column; gap:0;
    text-align:left; max-width:560px; margin:0 auto 56px;
  }

  .timeline-item {
    display:flex; gap:24px; align-items:flex-start;
    padding:20px 0;
    border-bottom:1px solid var(--border);
    opacity:0; transform:translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .timeline-item:last-child { border-bottom:none; }
  .timeline-item.visible { opacity:1; transform:translateY(0); }

  .timeline-dot {
    width:8px; height:8px; min-width:8px;
    border-radius:50%; background: var(--accent);
    margin-top:6px;
  }

  .timeline-content { flex:1; }

  .timeline-year {
    font-family: var(--mono); font-size:10px;
    letter-spacing:2px; color: var(--accent);
    margin-bottom:4px;
  }

  .timeline-text {
    font-size:14px; line-height:1.7; color: var(--text);
  }

  .hajun-link {
    display:inline-flex; align-items:center; gap:10px;
    background: var(--bg);
    border:1px solid rgba(201,169,110,0.3);
    padding: 20px 32px; border-radius:2px;
    text-decoration:none; color: var(--text);
    font-size:14px; transition:all 0.3s;
    cursor:pointer;
  }
  .hajun-link:hover {
    border-color: var(--accent);
    background: rgba(201,169,110,0.05);
    transform:translateY(-2px);
  }
  .hajun-link-icon { font-size:20px; }
  .hajun-link-text { text-align:left; }
  .hajun-link-label { font-family:var(--mono); font-size:9px; letter-spacing:2px; color:var(--accent); margin-bottom:4px; }
  .hajun-link-title { font-family:var(--serif); font-size:15px; }

  /* SURVEY */
  .survey-section {
    padding: 120px 24px;
    max-width:640px; margin:0 auto;
  }

  .step-indicator {
    display:flex; gap:4px; margin-bottom:56px;
  }
  .step-dot { height:2px; flex:1; background:var(--border); transition:background 0.4s; }
  .step-dot.active { background:var(--accent); }
  .step-dot.done   { background:var(--accent2); }

  .survey-step { display:none; animation:fadeUp 0.5s ease; }
  .survey-step.active { display:block; }

  .survey-question {
    font-family: var(--serif); font-size:22px;
    font-weight:300; line-height:1.5; margin-bottom:8px;
  }
  .survey-hint {
    font-size:12px; color: var(--muted);
    margin-bottom:36px; letter-spacing:0.5px;
  }

  .options-grid { display:grid; gap:8px; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); }

  .option-btn {
    background: var(--bg2); border:1px solid var(--border);
    color: var(--text); cursor:pointer;
    font-family: var(--sans); font-size:13px;
    padding:16px 20px; text-align:left;
    border-radius:2px; transition:all 0.25s;
    display:flex; align-items:center; gap:12px;
  }
  .option-btn:hover { border-color:var(--accent2); background:var(--bg3); }
  .option-btn.selected { border-color:var(--accent); background:rgba(201,169,110,0.08); color:var(--accent); }
  .option-icon { font-size:18px; width:24px; text-align:center; }

  .input-field {
    width:100%; background:var(--bg2);
    border:1px solid var(--border);
    color: var(--text); font-family:var(--sans);
    font-size:15px; padding:16px 20px;
    border-radius:2px; outline:none; transition:border-color 0.3s;
  }
  .input-field:focus { border-color:var(--accent); }
  .input-field::placeholder { color:var(--muted); }
  .input-row { display:flex; gap:8px; }
  .input-row .input-field { flex:1; }

  .checkbox-label {
    display:flex; align-items:flex-start; gap:12px;
    cursor:pointer; font-size:13px; color: var(--muted);
    line-height:1.6; padding:6px 0;
  }
  .checkbox-label input { display:none; }
  .custom-check {
    width:16px; height:16px; min-width:16px;
    border:1px solid var(--border); background:var(--bg);
    position:relative; margin-top:2px;
  }
  .checkbox-label input:checked + .custom-check { background:var(--accent); border-color:var(--accent); }
  .checkbox-label input:checked + .custom-check::after {
    content:'✓'; position:absolute;
    top:50%; left:50%; transform:translate(-50%,-50%);
    font-size:10px; color:#080808;
  }

  .survey-nav {
    display:flex; justify-content:space-between;
    align-items:center; margin-top:44px;
  }
  .btn-back {
    background:none; border:none; color:var(--muted);
    cursor:pointer; font-family:var(--sans); font-size:13px;
    display:flex; align-items:center; gap:6px; transition:color 0.2s;
  }
  .btn-back:hover { color:var(--text); }
  .btn-next {
    background:var(--accent); color:#080808;
    border:none; cursor:pointer;
    font-family:var(--sans); font-size:13px;
    font-weight:500; letter-spacing:1px;
    padding:14px 32px; border-radius:2px; transition:all 0.3s;
  }
  .btn-next:hover { background:#d4b47a; transform:translateY(-1px); }
  .btn-next:disabled { opacity:0.3; cursor:not-allowed; transform:none; }

  /* COMPLETE */
  .complete-screen {
    display:none; text-align:center; padding:48px 0;
    animation:fadeUp 0.6s ease;
  }
  .complete-screen.active { display:block; }
  .complete-icon {
    width:64px; height:64px;
    border:1px solid var(--accent); border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 28px; font-size:24px;
  }
  .complete-title {
    font-family:var(--serif); font-size:28px;
    font-weight:300; margin-bottom:16px;
  }
  .complete-desc {
    font-size:14px; color:var(--muted);
    line-height:1.9; margin-bottom:40px;
  }

  /* CONSULT */
  .consult-section {
    background: var(--bg2);
    border-top:1px solid var(--border);
    padding: 100px 24px;
    text-align:center;
  }
  .consult-inner { max-width:480px; margin:0 auto; }
  .consult-title {
    font-family:var(--serif); font-size:clamp(22px,3vw,34px);
    font-weight:300; line-height:1.4; margin-bottom:16px;
  }
  .consult-sub {
    font-size:14px; color:var(--muted);
    line-height:1.8; margin-bottom:48px;
  }
  .trust-list {
    display:flex; flex-direction:column; gap:8px;
    text-align:left; margin-bottom:48px;
  }
  .trust-row {
    display:flex; align-items:center; gap:12px;
    font-size:13px; color:var(--muted); padding:4px 0;
  }
  .trust-check { color:var(--accent); font-size:14px; }

  /* FAQ */
  .faq-section {
    padding:100px 24px;
    max-width:680px; margin:0 auto;
  }
  .faq-item {
    border-bottom:1px solid var(--border);
    padding:24px 0; cursor:pointer;
  }
  .faq-q {
    display:flex; justify-content:space-between; align-items:center;
    font-size:15px; font-weight:400; gap:16px;
  }
  .faq-toggle { color:var(--accent); font-size:18px; transition:transform 0.3s; min-width:20px; text-align:center; }
  .faq-a {
    font-size:13px; color:var(--muted);
    line-height:1.8; margin-top:16px;
    display:none;
  }
  .faq-item.open .faq-a { display:block; }
  .faq-item.open .faq-toggle { transform:rotate(45deg); }

  /* FOOTER */
  footer {
    border-top:1px solid var(--border);
    padding:40px 32px;
    display:flex; justify-content:space-between; align-items:center;
    flex-wrap:wrap; gap:16px;
  }
  .footer-logo {
    font-family:var(--serif); font-size:14px;
    letter-spacing:3px; color:var(--accent);
  }
  .footer-info {
    font-family:var(--mono); font-size:10px;
    color:var(--muted); line-height:1.8; text-align:right;
  }

  /* TOAST */
  .toast {
    position:fixed; bottom:32px; left:50%;
    transform:translateX(-50%) translateY(20px);
    background:var(--bg3); border:1px solid var(--border);
    color:var(--text); font-size:13px;
    padding:12px 24px; border-radius:2px;
    opacity:0; transition:all 0.4s;
    z-index:999; white-space:nowrap;
  }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
  .toast.success { border-color:rgba(90,170,122,0.4); color:#5aaa7a; }
  .toast.error   { border-color:rgba(224,90,90,0.4); color:#e05a5a; }

  @keyframes fadeUp {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
  @keyframes scrollPulse {
    0%,100% { opacity:0.3; } 50% { opacity:1; }
  }

  @media (max-width:600px) {
    header { padding:16px 20px; }
    .concern-grid { grid-template-columns:1fr; }
    .options-grid { grid-template-columns:1fr; }
    .input-row { flex-direction:column; }
    footer { flex-direction:column; text-align:center; }
    .footer-info { text-align:center; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <a href="#" class="logo">INTER<span>MARRY</span></a>
  <div class="header-right">POWERED BY BRAINPOOL</div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-label">INTERNATIONAL MARRIAGE · REAL LIFE GUIDE</div>
  <h1 class="hero-title">
    국제결혼,<br>
    결혼식보다 <em>그 이후의 삶</em>이<br>더 중요합니다.
  </h1>
  <p class="hero-sub">
    언어, 문화, 가족, 정착.<br>
    결혼 이후에 시작되는 진짜 이야기를<br>먼저 알아보세요.
  </p>
  <p class="hero-note">3분 내외 · 상담 강요 없음 · 개인정보 최소 수집</p>
  <div class="hero-cta">
    <button class="btn-primary" onclick="scrollToSurvey()">무료 준비도 진단 시작</button>
    <button class="btn-ghost" onclick="scrollToConsult()">1:1 상담 예약</button>
  </div>
  <div class="scroll-hint">
    <span>SCROLL</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- CONCERN -->
<section class="concern-section">
  <div class="section-eyebrow">REAL CONCERNS</div>
  <h2 class="section-title" style="margin-bottom:0;">
    많은 분들이 결혼 자체보다<br>결혼 후 생활을 더 걱정합니다.
  </h2>
  <div class="concern-grid">
    <div class="concern-item">
      <div class="concern-icon">💬</div>
      <div class="concern-title">언어</div>
      <div class="concern-desc">작은 오해가 큰 갈등이 되기도 합니다. 일상의 말 한마디가 관계를 바꿉니다.</div>
    </div>
    <div class="concern-item">
      <div class="concern-icon">🏡</div>
      <div class="concern-title">문화</div>
      <div class="concern-desc">같은 행동도 다르게 받아들여질 수 있습니다. 서로의 문화를 먼저 이해하는 것이 시작입니다.</div>
    </div>
    <div class="concern-item">
      <div class="concern-icon">👨‍👩‍👧</div>
      <div class="concern-title">가족</div>
      <div class="concern-desc">배우자뿐 아니라 양가 가족과의 관계도 중요합니다. 서로의 가족을 이해하는 시간이 필요합니다.</div>
    </div>
    <div class="concern-item">
      <div class="concern-icon">🌏</div>
      <div class="concern-title">정착</div>
      <div class="concern-desc">비자, 생활, 직장, 새로운 환경 적응. 결혼 이후 삶에는 준비가 필요합니다.</div>
    </div>
  </div>
</section>

<!-- JOURNEY -->
<section class="journey-section">
  <div class="journey-inner">
    <div class="section-eyebrow">REAL STORY</div>
    <h2 class="journey-title">
      실제로 이런 여정이<br>기록되고 있습니다.
    </h2>
    <p class="journey-sub">
      베트남에서 시작된 한 가족의 이야기.<br>
      결혼식이 아니라 그 이후의 삶 전체가 담겨있습니다.
    </p>

    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-year">BEGINNING</div>
          <div class="timeline-text">베트남에서 약혼. 두 나라, 두 문화가 만났습니다.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-year">LONG DISTANCE</div>
          <div class="timeline-text">장거리 1년. 언어와 거리를 넘어 연결되는 시간.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-year">PREPARATION</div>
          <div class="timeline-text">한국어 시험 준비. 새로운 언어로 새로운 삶을 준비했습니다.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-year">TOGETHER</div>
          <div class="timeline-text">결혼 그리고 한국 정착. 두 사람의 세계가 하나가 됐습니다.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-year">NEW LIFE · 2025.12.22</div>
          <div class="timeline-text">하준 출생. 그리고 100일. 이 모든 순간이 기록되어 있습니다.</div>
        </div>
      </div>
    </div>

    <a class="hajun-link" href="https://corenull1.vercel.app/hajun-100" target="_blank">
      <div class="hajun-link-icon">🥭</div>
      <div class="hajun-link-text">
        <div class="hajun-link-label">REAL RECORD · BRAINPOOL</div>
        <div class="hajun-link-title">김하준 100일 기록 보기 →</div>
      </div>
    </a>
  </div>
</section>

<!-- SURVEY -->
<section class="survey-section" id="survey">
  <div class="section-eyebrow" style="margin-bottom:12px;">FREE DIAGNOSIS</div>
  <h2 class="section-title" style="margin-bottom:8px;">
    지금 어떤 상황인지<br>먼저 확인해보세요.
  </h2>
  <p class="section-body" style="margin-bottom:48px;">
    3분이면 충분합니다. 결정이 아니라 이해가 먼저입니다.
  </p>

  <div class="step-indicator" id="stepIndicator"></div>

  <!-- STEP 1 -->
  <div class="survey-step active" id="step1">
    <div class="survey-question">현재 상황이 어떻게 되시나요?</div>
    <div class="survey-hint">가장 가까운 상황을 선택해주세요</div>
    <div class="options-grid">
      <button class="option-btn" onclick="selectOption(this,'s_status','국제결혼 준비 중')">
        <span class="option-icon">💍</span> 국제결혼 준비 중
      </button>
      <button class="option-btn" onclick="selectOption(this,'s_status','연애 중')">
        <span class="option-icon">❤️</span> 연애 중
      </button>
      <button class="option-btn" onclick="selectOption(this,'s_status','이미 결혼함')">
        <span class="option-icon">🏡</span> 이미 결혼함
      </button>
      <button class="option-btn" onclick="selectOption(this,'s_status','그냥 궁금해서')">
        <span class="option-icon">🤔</span> 그냥 궁금해서
      </button>
    </div>
    <div class="survey-nav">
      <div></div>
      <button class="btn-next" id="nextBtn1" onclick="nextStep(1)" disabled>다음 →</button>
    </div>
  </div>

  <!-- STEP 2: 집 이름 (CoreNull 연결 포인트) -->
  <div class="survey-step" id="step2">
    <div class="survey-question">우리 공간 이름을 지어볼까요?</div>
    <div class="survey-hint">나중에 실제 기록 공간이 됩니다 · 예: 하준이네, 김&응옥, 우리가족</div>
    <div style="display:flex; flex-direction:column; gap:12px;">
      <input type="text" id="s_house" class="input-field" placeholder="우리 공간 이름 (예: 하준이네)">
    </div>
    <div class="survey-nav">
      <button class="btn-back" onclick="prevStep(2)">← 이전</button>
      <button class="btn-next" onclick="nextStep(2)">다음 →</button>
    </div>
  </div>

  <!-- STEP 3: 연락처 -->
  <div class="survey-step" id="step3">
    <div class="survey-question">기본 정보를 알려주세요</div>
    <div class="survey-hint">상담 연결을 위해서만 사용됩니다</div>
    <div style="display:flex; flex-direction:column; gap:12px;">
      <div class="input-row">
        <input type="text" id="s_name" class="input-field" placeholder="성함">
        <input type="number" id="s_age" class="input-field" placeholder="나이" style="max-width:110px;" min="20" max="70">
      </div>
      <input type="tel" id="s_phone" class="input-field" placeholder="연락처 (010-0000-0000)">
    </div>
    <div class="survey-nav">
      <button class="btn-back" onclick="prevStep(3)">← 이전</button>
      <button class="btn-next" onclick="nextStep(3)">다음 →</button>
    </div>
  </div>

  <!-- STEP 4: 관심 국가 -->
  <div class="survey-step" id="step4">
    <div class="survey-question">관심 있는 국가는?</div>
    <div class="survey-hint">복수 선택 가능합니다</div>
    <div class="options-grid">
      <button class="option-btn" onclick="toggleMulti(this,'s_country','베트남')">
        <span class="option-icon">🇻🇳</span> 베트남
      </button>
      <button class="option-btn" onclick="toggleMulti(this,'s_country','캄보디아')">
        <span class="option-icon">🇰🇭</span> 캄보디아
      </button>
      <button class="option-btn" onclick="toggleMulti(this,'s_country','러시아')">
        <span class="option-icon">🇷🇺</span> 러시아
      </button>
      <button class="option-btn" onclick="toggleMulti(this,'s_country','일본')">
        <span class="option-icon">🇯🇵</span> 일본
      </button>
    </div>
    <div class="survey-nav">
      <button class="btn-back" onclick="prevStep(4)">← 이전</button>
      <button class="btn-next" onclick="nextStep(4)">다음 →</button>
    </div>
  </div>

  <!-- STEP 5: 걱정 -->
  <div class="survey-step" id="step5">
    <div class="survey-question">가장 걱정되는 부분은?</div>
    <div class="survey-hint">해당하는 것을 모두 선택해주세요</div>
    <div style="display:flex; flex-direction:column; gap:4px;">
      <label class="checkbox-label">
        <input type="checkbox" value="언어 소통" onchange="toggleConcern(this)">
        <span class="custom-check"></span> 언어 소통이 불안하다
      </label>
      <label class="checkbox-label">
        <input type="checkbox" value="문화 차이" onchange="toggleConcern(this)">
        <span class="custom-check"></span> 문화 차이가 걱정된다
      </label>
      <label class="checkbox-label">
        <input type="checkbox" value="가족 관계" onchange="toggleConcern(this)">
        <span class="custom-check"></span> 양가 가족 관계가 걱정된다
      </label>
      <label class="checkbox-label">
        <input type="checkbox" value="정착 문제" onchange="toggleConcern(this)">
        <span class="custom-check"></span> 정착과 비자 문제가 복잡하다
      </label>
      <label class="checkbox-label">
        <input type="checkbox" value="사기 피해" onchange="toggleConcern(this)">
        <span class="custom-check"></span> 사기 피해가 걱정된다
      </label>
    </div>
    <div class="survey-nav">
      <button class="btn-back" onclick="prevStep(5)">← 이전</button>
      <button class="btn-next" onclick="submitSurvey()">결과 확인 →</button>
    </div>
  </div>

  <!-- COMPLETE -->
  <div class="complete-screen" id="completeScreen">
    <div class="complete-icon">✦</div>
    <h3 class="complete-title">접수되었습니다</h3>
    <p class="complete-desc">
      담당자가 24시간 이내에 연락드립니다.<br>
      상담은 계약이 아니라 이해를 위한 시간입니다.<br><br>
      <span style="color:var(--accent); font-size:13px;">곧 출시될 기록 공간에서 우리 가족의 여정을 담아보세요.</span>
    </p>
    <button class="btn-primary" onclick="scrollToConsult()" style="width:100%; margin-bottom:12px;">
      1:1 상담 예약하기
    </button>
  </div>
</section>

<!-- CONSULT -->
<section class="consult-section" id="consult">
  <div class="consult-inner">
    <div class="section-eyebrow" style="margin-bottom:20px;">FREE CONSULTATION</div>
    <h2 class="consult-title">
      상담은 계약이 아닙니다.<br>
      먼저 충분히 알아보세요.
    </h2>
    <p class="consult-sub">
      국제결혼이 나에게 맞는지 확인하고,<br>
      결혼 이후 삶을 함께 준비하는 시간입니다.
    </p>
    <div class="trust-list">
      <div class="trust-row"><span class="trust-check">✓</span> 상담 비용 없음</div>
      <div class="trust-row"><span class="trust-check">✓</span> 상담 후 계약 강요 없음</div>
      <div class="trust-row"><span class="trust-check">✓</span> 개인정보 상담 목적 외 사용 안 함</div>
      <div class="trust-row"><span class="trust-check">✓</span> 국제결혼이 맞지 않으면 솔직하게 말씀드립니다</div>
    </div>
    <button class="btn-primary" onclick="scrollToSurvey()" style="width:100%;">
      무료 준비도 진단 시작
    </button>
  </div>
</section>

<!-- FAQ -->
<section class="faq-section">
  <div class="section-eyebrow" style="margin-bottom:20px;">FAQ</div>
  <h2 class="section-title" style="margin-bottom:48px;">자주 묻는 질문</h2>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">
      <span>상담은 무료인가요?</span>
      <span class="faq-toggle">+</span>
    </div>
    <div class="faq-a">네. 상담 비용은 없습니다. 부담 없이 문의해주세요.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">
      <span>상담 후 바로 계약해야 하나요?</span>
      <span class="faq-toggle">+</span>
    </div>
    <div class="faq-a">아닙니다. 충분히 검토하신 뒤 결정하셔도 됩니다. 강요하지 않습니다.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">
      <span>개인정보는 어떻게 관리되나요?</span>
      <span class="faq-toggle">+</span>
    </div>
    <div class="faq-a">상담 목적 외에는 사용되지 않습니다. 제3자에게 제공하지 않습니다.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">
      <span>국제결혼을 꼭 해야 하나요?</span>
      <span class="faq-toggle">+</span>
    </div>
    <div class="faq-a">아닙니다. 상담을 통해 본인에게 맞는 방향을 찾는 것이 더 중요합니다. 맞지 않으면 솔직하게 말씀드립니다.</div>
  </div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">
      <span>준비도 진단에서 무엇을 알 수 있나요?</span>
      <span class="faq-toggle">+</span>
    </div>
    <div class="faq-a">현재 상황, 걱정되는 부분, 준비 단계를 파악하고 담당자가 맞춤 안내를 드립니다.</div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">INTERMARRY</div>
  <div class="footer-info">
    국제결혼중개업 신고업체 · 결혼중개업법 준수<br>
    POWERED BY BRAINPOOL
  </div>
</footer>

<div class="toast" id="toast"></div>

<script>
const SUPABASE_URL  = "https://grlfocvlfatuvphkyivd.supabase.co";
const SUPABASE_ANON = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdybGZvY3ZsZmF0dXZwaGt5aXZkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzAzNDM1MzksImV4cCI6MjA4NTkxOTUzOX0.4dLzD1AYSuigxU_Q5ZZwZ6XDGejMvbuoYIjmB4D7dxo";

const params = new URLSearchParams(window.location.search);
const UTM = {
  source:  params.get('utm_source')  || 'direct',
  medium:  params.get('utm_medium')  || '',
  content: params.get('utm_content') || '',
};

const TOTAL_STEPS = 5;
let currentStep = 1;
const surveyData = { status:'', house:'', name:'', age:null, phone:'', country:[], concerns:[] };

function buildIndicator() {
  const el = document.getElementById('stepIndicator');
  el.innerHTML = '';
  for (let i = 1; i <= TOTAL_STEPS; i++) {
    const dot = document.createElement('div');
    dot.className = 'step-dot' + (i < currentStep ? ' done' : i === currentStep ? ' active' : '');
    el.appendChild(dot);
  }
}
buildIndicator();

function scrollToSurvey()  { document.getElementById('survey').scrollIntoView({ behavior:'smooth' }); }
function scrollToConsult() { document.getElementById('consult').scrollIntoView({ behavior:'smooth' }); }

function selectOption(btn, key, val) {
  btn.closest('.options-grid').querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  surveyData[key] = val;
  const nb = document.getElementById('nextBtn' + currentStep);
  if (nb) nb.disabled = false;
}

function toggleMulti(btn, key, val) {
  btn.classList.toggle('selected');
  if (!surveyData[key]) surveyData[key] = [];
  if (btn.classList.contains('selected')) surveyData[key].push(val);
  else surveyData[key] = surveyData[key].filter(v => v !== val);
}

function toggleConcern(cb) {
  if (cb.checked) surveyData.concerns.push(cb.value);
  else surveyData.concerns = surveyData.concerns.filter(v => v !== cb.value);
}

function nextStep(from) {
  if (from === 3) {
    const name  = document.getElementById('s_name').value.trim();
    const age   = document.getElementById('s_age').value;
    const phone = document.getElementById('s_phone').value.trim();
    if (!name || !age || !phone) { showToast('모든 항목을 입력해주세요', 'error'); return; }
    surveyData.name  = name;
    surveyData.age   = parseInt(age);
    surveyData.phone = phone;
  }
  if (from === 2) {
    surveyData.house = document.getElementById('s_house').value.trim() || '우리 가족';
  }
  document.getElementById('step' + from).classList.remove('active');
  currentStep = from + 1;
  document.getElementById('step' + currentStep).classList.add('active');
  buildIndicator();
  document.getElementById('survey').scrollIntoView({ behavior:'smooth', block:'start' });
}

function prevStep(from) {
  document.getElementById('step' + from).classList.remove('active');
  currentStep = from - 1;
  document.getElementById('step' + currentStep).classList.add('active');
  buildIndicator();
}

async function submitSurvey() {
  const payload = {
    name:         surveyData.name,
    age:          surveyData.age,
    phone:        surveyData.phone,
    status:       surveyData.status,
    house_name:   surveyData.house,
    country:      surveyData.country.join(','),
    concerns:     surveyData.concerns.join(','),
    utm_source:   UTM.source,
    utm_medium:   UTM.medium,
    utm_content:  UTM.content,
    client_id:    'intermarry',
    paid:         false,
    converted:    false,
  };

  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/leads`, {
      method: 'POST',
      headers: {
        'Content-Type':  'application/json',
        'apikey':         SUPABASE_ANON,
        'Authorization': `Bearer ${SUPABASE_ANON}`,
        'Prefer':         'return=minimal',
      },
      body: JSON.stringify(payload),
    });
    if (!res.ok) console.warn('[Lead]', await res.text());
    else showToast('접수 완료! 곧 연락드리겠습니다 ✦', 'success');
  } catch(e) { console.warn('[Lead]', e.message); }

  document.getElementById('step5').classList.remove('active');
  document.getElementById('completeScreen').classList.add('active');
  document.getElementById('stepIndicator').style.display = 'none';
  document.getElementById('survey').scrollIntoView({ behavior:'smooth' });
}

function toggleFaq(item) {
  item.classList.toggle('open');
}

function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast ' + type + ' show';
  setTimeout(() => t.classList.remove('show'), 3500);
}

// Timeline scroll animation
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.2 });

document.querySelectorAll('.timeline-item').forEach((el, i) => {
  el.style.transitionDelay = (i * 0.1) + 's';
  observer.observe(el);
});

// Concern items
const observer2 = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.concern-item').forEach((el, i) => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(20px)';
  el.style.transition = `opacity 0.6s ease ${i * 0.1}s, transform 0.6s ease ${i * 0.1}s`;
  observer2.observe(el);
});
</script>
</body>
</html>

      p("단, 온라인 전략의 방향(무료 진단 + DB 수집)은 유지됩니다. 세부 문구나 디자인 수정은 반영 가능합니다.", { color: "666666" }),
      space(),
      space(),

      // 마무리
      new Paragraph({
        border: { top: { style: BorderStyle.SINGLE, size: 4, color: "C9A96E", space: 1 } },
        alignment: AlignmentType.CENTER,
        spacing: { before: 240 },
        children: [new TextRun({ text: "INTERMARRY — 국제결혼의 현실을 먼저 이해하게 돕고, 그 이후 삶까지 연결합니다.", size: 18, font: "Arial", color: "999999", italics: true })]
      })
    ]
  }]
});

Packer.toBuffer(doc).then(buffer => {
  fs.writeFileSync("/mnt/user-data/outputs/인터메리_온라인전략_정리문서.docx", buffer);
  console.log("✅ 완료");
});